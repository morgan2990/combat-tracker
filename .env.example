MONGODB_URI=mongodb://user:password@host:27017/combatapp?authSource=admin
MINIO_ENDPOINT=host:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=pdfs
TYPESENSE_URL=http://host:8108
TYPESENSE_API_KEY=
# false for local/LAN HTTP testing so the session cookie isn't rejected;
# leave unset (defaults to true) for real deployments behind HTTPS.
COOKIE_SECURE=false
PORT=8080

# Local 5etools repo checkouts, used only by scripts/run-scrubber.ps1 to
# default the --source path per edition so it doesn't have to be typed
# on every run.
SCRUBBER_SOURCE_5E=
SCRUBBER_SOURCE_5_5E=
